generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Container {
  id        String   @id @default(cuid())
  weight    Float
  fraction  String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("containers")
}

model Calculation {
  id          String   @id @default(cuid())
  name        String
  targetWeight Float
  fraction    String?
  allowMixing Boolean  @default(false)
  result      Json
  totalWeight  Float
  overweight   Float
  createdAt   DateTime @default(now())

  @@map("calculations")
}
