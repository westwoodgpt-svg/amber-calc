generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Container {
  id              String   @id @default(cuid())
  name            String
  type            String   @default("fraction")
  share           Float    @default(0)
  packWeight      Float    @default(10)
  weightConfirmed Boolean  @default(false)
  balance         Float    @default(0)

  // Legacy fields kept for backward DB compatibility
  category  String  @default("fraction")
  fraction  String?
  weight    Float   @default(0)
  quantity  Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("containers")
}

model Calculation {
  id           String   @id @default(cuid())
  name         String
  targetWeight Float
  category     String?
  fraction     String?
  allowMixing  Boolean  @default(false)
  result       Json
  totalWeight  Float
  overweight   Float
  createdAt    DateTime @default(now())

  @@map("calculations")
}