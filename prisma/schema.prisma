generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// VES  = weight-sorted fractions, boxes ~10 kg
// SITO = sieve (unsorted fractional), bags ~25 kg
// LAK  = black lacquer, boxes ~10 kg
enum ItemType {
  VES
  SITO
  LAK
}

model Item {
  id              String   @id @default(cuid())
  name            String
  article         String   @unique
  type            ItemType
  packWeight      Float
  lotKg           Float    @default(0)
  weightConfirmed Boolean  @default(true)

  histories       CalculationHistory[]
  calculationRows CalculationItem[]
  exclusions      CompanyExclusion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyOrder {
  id          String @id @default(cuid())
  year        Int    @default(2026)
  companyName String
  vesKg       Float  @default(0)
  sitoKg      Float  @default(0)
  lakKg       Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyName, year])
}

model Calculation {
  id               String            @id @default(cuid())
  status           CalculationStatus @default(COMPLETED)
  companyName      String            @default("")
  totalWeight      Float
  totalActual      Float
  totalDelta       Float
  allowPartialPack Boolean           @default(false)
  shipmentNumber   Int               @default(1)
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())

  items     CalculationItem[]
  histories CalculationHistory[]
}

enum CalculationStatus {
  COMPLETED
}

model CalculationItem {
  id             String @id @default(cuid())
  calculationId  String
  itemId         String
  calcWeight     Float
  adjustedWeight Float
  packs          Int
  factWeight     Float
  delta          Float

  calculation Calculation @relation(fields: [calculationId], references: [id], onDelete: Cascade)
  item        Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model CalculationHistory {
  id            String   @id @default(cuid())
  calculationId String
  itemId        String
  delta         Float
  createdAt     DateTime @default(now())

  calculation Calculation @relation(fields: [calculationId], references: [id], onDelete: Cascade)
  item        Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

// Per-company item exclusions: these items are skipped (lot share redistributed to the rest)
model CompanyExclusion {
  id          String @id @default(cuid())
  companyName String
  year        Int    @default(2026)
  itemId      String

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([companyName, year, itemId])
}
